{
  "hosting": {
    "public": "out",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false,

    "headers": [
      {
        "source": "/api/**",
        "headers": [
          { "key": "Access-Control-Allow-Origin", "value": "*" },
          { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
          { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=600" },
          { "key": "Content-Type", "value": "application/json; charset=utf-8" }
        ]
      }
    ],

    "redirects": [
      {
        "source": "http://www.zachary-sturman.com/**",
        "destination": "https://zachary-sturman.com/$1",
        "type": 301
      },
      {
        "source": "https://www.zachary-sturman.com/**",
        "destination": "https://zachary-sturman.com/$1",
        "type": 301
      },
      {
        "source": "http://zachary-sturman.com/**",
        "destination": "https://zachary-sturman.com/$1",
        "type": 301
      }
    ]
  },
  "emulators": {
    "hosting": {
      "port": 5033
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  }
}

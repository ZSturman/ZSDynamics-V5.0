# ---------------------------------------------------------------------------
# Notion API (server-side only — used by the Python build pipeline)
# Required by lib/notion_projects_export.py (run via `npm run fetch-notion-projects`).
# Create a Notion integration at https://www.notion.so/my-integrations and add
# its "Internal Integration Token" as NOTION_API_KEY. Then add the integration
# as a connection on each of the six databases listed below.
# ---------------------------------------------------------------------------
NOTION_API_KEY=

# Notion database IDs (copy from the URL of each database page in Notion)
NOTION_PROJECTS_DB_ID=
NOTION_COLLECTIONS_DB_ID=
NOTION_ASSETS_DB_ID=
NOTION_RESOURCES_DB_ID=
NOTION_CONFIG_DB_ID=
NOTION_WORK_LOGS_DB_ID=

NEXT_PUBLIC_FIREBASE_ANALYTICS_ENABLED=false
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ---------------------------------------------------------------------------
# Cloudflare Worker (contact form, newsletter interest, daily summary mailer)
# Used by the frontend to call the Worker endpoints. The Worker URL is public.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=
# Cloudflare Turnstile site key (public). Server secret lives in the Worker.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---------------------------------------------------------------------------
# Cloudflare R2 media (server-side only — used by the Python build pipeline)
# Leave unset to disable hosted media uploads. The pipeline still works without
# these and will keep referencing local repo media.
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=https://media.zacharysturman.com

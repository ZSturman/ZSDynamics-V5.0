    "hooks:install": "node scripts/install-hooks.mjs",
    "hooks:pre-push": "bash .githooks/pre-push",
    "generate-articles": "python3 lib/sync_articles.py",
    "generate-projects": "python3 lib/folio-prebuild.py --input-json /Users/zacharysturman/n8n-files/exports/new_projects.json",
    "optimize": "python3 lib/media-optimizer.py public/projects --delete-originals"
  },
